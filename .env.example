# PostHog analytics (optional). Copy this file to `.env` and fill in your keys.
# Without these the game runs exactly the same, but no analytics are sent.
#
# The key is a PostHog *public* project key — it is meant to be exposed in
# client-side code. Create a project at https://posthog.com and copy its
# "Project API Key" from Project Settings.

VITE_POSTHOG_KEY=
# EU cloud (default if unset): https://eu.i.posthog.com
# US cloud:                     https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com
